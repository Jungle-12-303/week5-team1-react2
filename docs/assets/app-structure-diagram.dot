digraph "앱_컴포넌트_구조도" {
  graph [
    rankdir=TB,
    bgcolor="#f7f8fc",
    fontname="Apple SD Gothic Neo",
    labelloc="t",
    label="앱 컴포넌트 구조도",
    fontsize=24,
    fontcolor="#0f172a",
    pad=0.45,
    nodesep=0.5,
    ranksep=0.9,
    splines=spline,
    compound=true
  ];

  node [
    shape=plain,
    fontname="Apple SD Gothic Neo",
    fontsize=11
  ];

  edge [
    fontname="Apple SD Gothic Neo",
    fontsize=10,
    color="#64748b",
    arrowsize=0.8,
    penwidth=1.2
  ];

  subgraph "cluster_부트스트랩" {
    label="부트스트랩";
    color="#93c5fd";
    style="rounded,filled";
    fillcolor="#eff6ff";
    penwidth=1.4;

    "메인_시작점" [
      label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="8" COLOR="#93c5fd">
          <TR><TD BGCOLOR="#dbeafe"><B>메인 시작점</B></TD></TR>
          <TR><TD ALIGN="LEFT" BGCOLOR="#f8fbff">브라우저 시작점<BR/>루트 문서 노드 획득</TD></TR>
        </TABLE>
      >
    ];

    "앱_생성기" [
      label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="8" COLOR="#93c5fd">
          <TR><TD BGCOLOR="#dbeafe"><B>앱 생성기</B></TD></TR>
          <TR><TD ALIGN="LEFT" BGCOLOR="#f8fbff">루트 런타임 생성<BR/>장착 / 점검 제공</TD></TR>
        </TABLE>
      >
    ];

    "루트_앱" [
      label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="8" COLOR="#60a5fa">
          <TR><TD BGCOLOR="#bfdbfe"><B>루트 앱</B></TD></TR>
          <TR><TD ALIGN="LEFT" BGCOLOR="#f8fbff">단일 루트 상태 저장소<BR/>페이지 분기 / 데이터 로드</TD></TR>
        </TABLE>
      >
    ];
  }

  subgraph "cluster_데이터계층" {
    label="데이터 계층";
    color="#fbbf24";
    style="rounded,filled";
    fillcolor="#fffbeb";
    penwidth=1.4;

    "카드_라이브러리" [
      label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="8" COLOR="#f59e0b">
          <TR><TD BGCOLOR="#fde68a"><B>카드 라이브러리</B></TD></TR>
          <TR><TD ALIGN="LEFT" BGCOLOR="#fffdf5">메타데이터<BR/>대체 카드</TD></TR>
        </TABLE>
      >
    ];

    "포케_API" [
      label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="8" COLOR="#f59e0b">
          <TR><TD BGCOLOR="#fde68a"><B>포켓몬 API 클라이언트</B></TD></TR>
          <TR><TD ALIGN="LEFT" BGCOLOR="#fffdf5">카탈로그 로드<BR/>상세 데이터 요청</TD></TR>
        </TABLE>
      >
    ];
  }

  subgraph "cluster_앱셸" {
    label="앱 셸";
    color="#c4b5fd";
    style="rounded,filled";
    fillcolor="#f5f3ff";
    penwidth=1.4;

    "공통_레이아웃" [
      label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="8" COLOR="#a78bfa">
          <TR><TD BGCOLOR="#ddd6fe"><B>공통 레이아웃</B></TD></TR>
          <TR><TD ALIGN="LEFT" BGCOLOR="#faf8ff">공통 레이아웃<BR/>페이지 외곽 구조</TD></TR>
        </TABLE>
      >
    ];

    "상단_탐색" [
      label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="8" COLOR="#a78bfa">
          <TR><TD BGCOLOR="#ede9fe"><B>상단 탐색</B></TD></TR>
          <TR><TD ALIGN="LEFT" BGCOLOR="#faf8ff">데스크톱 상단 메뉴</TD></TR>
        </TABLE>
      >
    ];

    "하단_탭바" [
      label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="8" COLOR="#a78bfa">
          <TR><TD BGCOLOR="#ede9fe"><B>하단 탭 바</B></TD></TR>
          <TR><TD ALIGN="LEFT" BGCOLOR="#faf8ff">모바일 하단 탭</TD></TR>
        </TABLE>
      >
    ];
  }

  subgraph "cluster_페이지" {
    label="페이지 컴포넌트";
    color="#fda4af";
    style="rounded,filled";
    fillcolor="#fff1f2";
    penwidth=1.4;

    "대시보드_페이지" [
      label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="8" COLOR="#fb7185">
          <TR><TD BGCOLOR="#fecdd3"><B>대시보드 페이지</B></TD></TR>
          <TR><TD ALIGN="LEFT" BGCOLOR="#fff8f8">요약 대시보드<BR/>스포트라이트 카드</TD></TR>
        </TABLE>
      >
    ];

    "컬렉션_페이지" [
      label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="8" COLOR="#fb7185">
          <TR><TD BGCOLOR="#fecdd3"><B>컬렉션 페이지</B></TD></TR>
          <TR><TD ALIGN="LEFT" BGCOLOR="#fff8f8">검색 / 필터 / 목록</TD></TR>
        </TABLE>
      >
    ];

    "상세_페이지" [
      label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="8" COLOR="#fb7185">
          <TR><TD BGCOLOR="#fecdd3"><B>상세 페이지</B></TD></TR>
          <TR><TD ALIGN="LEFT" BGCOLOR="#fff8f8">선택 카드 상세<BR/>상태 기반 기울기 데모</TD></TR>
        </TABLE>
      >
    ];

    "설정_페이지" [
      label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="8" COLOR="#fb7185">
          <TR><TD BGCOLOR="#fecdd3"><B>설정 페이지</B></TD></TR>
          <TR><TD ALIGN="LEFT" BGCOLOR="#fff8f8">설정 패널</TD></TR>
        </TABLE>
      >
    ];
  }

  subgraph "cluster_공용UI" {
    label="공용 UI 조각";
    color="#86efac";
    style="rounded,filled";
    fillcolor="#f0fdf4";
    penwidth=1.4;

    "페이지_헤더" [
      label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="8" COLOR="#4ade80">
          <TR><TD BGCOLOR="#dcfce7"><B>페이지 헤더</B></TD></TR>
          <TR><TD ALIGN="LEFT" BGCOLOR="#f9fff9">페이지 상단 헤더</TD></TR>
        </TABLE>
      >
    ];

    "요약_카드" [
      label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="8" COLOR="#4ade80">
          <TR><TD BGCOLOR="#dcfce7"><B>요약 카드</B></TD></TR>
          <TR><TD ALIGN="LEFT" BGCOLOR="#f9fff9">요약 정보 카드</TD></TR>
        </TABLE>
      >
    ];

    "목록_카드" [
      label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="8" COLOR="#4ade80">
          <TR><TD BGCOLOR="#dcfce7"><B>목록 카드</B></TD></TR>
          <TR><TD ALIGN="LEFT" BGCOLOR="#f9fff9">대시보드 / 목록 카드<BR/>직접 문서 노드 호버 효과</TD></TR>
        </TABLE>
      >
    ];

    "컬렉션_도구막대" [
      label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="8" COLOR="#4ade80">
          <TR><TD BGCOLOR="#dcfce7"><B>컬렉션 도구막대</B></TD></TR>
          <TR><TD ALIGN="LEFT" BGCOLOR="#f9fff9">검색 / 정렬 / 필터</TD></TR>
        </TABLE>
      >
    ];

    "상세_카드_프리뷰" [
      label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="8" COLOR="#4ade80">
          <TR><TD BGCOLOR="#dcfce7"><B>상세 카드 프리뷰</B></TD></TR>
          <TR><TD ALIGN="LEFT" BGCOLOR="#f9fff9">상세 카드 프리뷰<BR/>런타임 상태 기반 기울기</TD></TR>
        </TABLE>
      >
    ];
  }

  "메인_시작점" -> "앱_생성기" [label="앱 시작"];
  "앱_생성기" -> "루트_앱" [label="루트 상태 연결"];

  "루트_앱" -> "카드_라이브러리" [label="대체 데이터 사용", lhead="cluster_데이터계층"];
  "루트_앱" -> "포케_API" [label="원격 데이터 요청", lhead="cluster_데이터계층"];
  "루트_앱" -> "공통_레이아웃" [label="공통 셸 구성", lhead="cluster_앱셸"];
  "루트_앱" -> "대시보드_페이지" [label="현재 페이지 = 대시보드", lhead="cluster_페이지"];
  "루트_앱" -> "컬렉션_페이지" [label="현재 페이지 = 컬렉션", lhead="cluster_페이지"];
  "루트_앱" -> "상세_페이지" [label="현재 페이지 = 상세", lhead="cluster_페이지"];
  "루트_앱" -> "설정_페이지" [label="현재 페이지 = 설정", lhead="cluster_페이지"];

  "공통_레이아웃" -> "상단_탐색" [label="데스크톱 탐색"];
  "공통_레이아웃" -> "하단_탭바" [label="모바일 탐색"];

  "대시보드_페이지" -> "페이지_헤더" [label="헤더"];
  "대시보드_페이지" -> "요약_카드" [label="핵심 지표 요약"];
  "대시보드_페이지" -> "목록_카드" [label="스포트라이트 카드"];

  "컬렉션_페이지" -> "페이지_헤더" [label="헤더"];
  "컬렉션_페이지" -> "컬렉션_도구막대" [label="검색 / 필터"];
  "컬렉션_페이지" -> "목록_카드" [label="가상 스크롤 카드 목록"];

  "상세_페이지" -> "페이지_헤더" [label="헤더"];
  "상세_페이지" -> "요약_카드" [label="희귀도 / 종족값 합"];
  "상세_페이지" -> "상세_카드_프리뷰" [label="상세 카드 프리뷰"];

  "설정_페이지" -> "페이지_헤더" [label="헤더"];
}
