digraph "런타임_클래스_다이어그램" {
  graph [
    rankdir=LR,
    bgcolor="#f7f8fc",
    fontname="Apple SD Gothic Neo",
    labelloc="t",
    label="런타임 클래스 다이어그램",
    fontsize=24,
    fontcolor="#0f172a",
    pad=0.45,
    nodesep=0.6,
    ranksep=1.0,
    splines=spline,
    compound=true
  ];

  node [
    shape=plain,
    fontname="Apple SD Gothic Neo",
    fontsize=11
  ];

  edge [
    fontname="Apple SD Gothic Neo",
    fontsize=10,
    color="#64748b",
    arrowsize=0.8,
    penwidth=1.2
  ];

  subgraph "cluster_공개진입점" {
    label="공개 진입점";
    color="#c7d2fe";
    style="rounded,filled";
    fillcolor="#eef2ff";
    penwidth=1.4;

    "앱_퍼사드" [
      label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="8" COLOR="#93c5fd">
          <TR><TD BGCOLOR="#dbeafe"><B>앱 생성 퍼사드</B></TD></TR>
          <TR><TD ALIGN="LEFT" BGCOLOR="#f8fbff">앱 장착<BR/>속성 교체<BR/>앱 해제<BR/>상태 점검</TD></TR>
        </TABLE>
      >
    ];
  }

  subgraph "cluster_루트런타임" {
    label="루트 런타임";
    color="#fcd34d";
    style="rounded,filled";
    fillcolor="#fffbeb";
    penwidth=1.4;

    "루트_컴포넌트" [
      label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="8" COLOR="#f59e0b">
          <TR><TD BGCOLOR="#fde68a"><B>루트 컴포넌트 관리자</B></TD></TR>
          <TR><TD ALIGN="LEFT" BGCOLOR="#fffdf5">루트 렌더 함수<BR/>훅 저장 배열<BR/>훅 읽기 커서<BR/>현재 속성<BR/>현재 가상 트리<BR/>루트 문서 노드<BR/>장착 여부<BR/>장착 / 갱신 / 해제</TD></TR>
        </TABLE>
      >
    ];

    "현재_디스패처" [
      label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="8" COLOR="#fbbf24">
          <TR><TD BGCOLOR="#fef3c7"><B>현재 디스패처</B></TD></TR>
          <TR><TD ALIGN="LEFT" BGCOLOR="#fffdf5">활성 루트<BR/>훅 허용 여부</TD></TR>
        </TABLE>
      >
    ];

    "자식_트리_전개" [
      label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="8" COLOR="#fbbf24">
          <TR><TD BGCOLOR="#fef3c7"><B>자식 트리 전개기</B></TD></TR>
          <TR><TD ALIGN="LEFT" BGCOLOR="#fffdf5">자식 함수 컴포넌트 전개<BR/>자식 훅 금지</TD></TR>
        </TABLE>
      >
    ];

    "업데이트_예약" [
      label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="8" COLOR="#fbbf24">
          <TR><TD BGCOLOR="#fef3c7"><B>업데이트 예약기</B></TD></TR>
          <TR><TD ALIGN="LEFT" BGCOLOR="#fffdf5">동기 / 마이크로태스크 분기<BR/>중복 예약 방지</TD></TR>
        </TABLE>
      >
    ];

    "이펙트_커밋" [
      label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="8" COLOR="#fbbf24">
          <TR><TD BGCOLOR="#fef3c7"><B>이펙트 커밋기</B></TD></TR>
          <TR><TD ALIGN="LEFT" BGCOLOR="#fffdf5">정리 함수 실행<BR/>부수 효과 실행<BR/>의존값 확정</TD></TR>
        </TABLE>
      >
    ];

    "언마운트_정리" [
      label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="8" COLOR="#fbbf24">
          <TR><TD BGCOLOR="#fef3c7"><B>언마운트 정리기</B></TD></TR>
          <TR><TD ALIGN="LEFT" BGCOLOR="#fffdf5">이벤트 / 부수 효과 / 문서 노드 정리</TD></TR>
        </TABLE>
      >
    ];
  }

  subgraph "cluster_Hook계층" {
    label="훅 계층";
    color="#a5b4fc";
    style="rounded,filled";
    fillcolor="#eef2ff";
    penwidth=1.4;

    "상태_Hook" [
      label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="8" COLOR="#818cf8">
          <TR><TD BGCOLOR="#e0e7ff"><B>상태 훅</B></TD></TR>
          <TR><TD ALIGN="LEFT" BGCOLOR="#f8faff">상태 슬롯 생성<BR/>상태 변경 함수 생성</TD></TR>
        </TABLE>
      >
    ];

    "이펙트_Hook" [
      label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="8" COLOR="#818cf8">
          <TR><TD BGCOLOR="#e0e7ff"><B>이펙트 훅</B></TD></TR>
          <TR><TD ALIGN="LEFT" BGCOLOR="#f8faff">이펙트 슬롯 생성<BR/>의존값 비교</TD></TR>
        </TABLE>
      >
    ];

    "메모_Hook" [
      label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="8" COLOR="#818cf8">
          <TR><TD BGCOLOR="#e0e7ff"><B>메모 훅</B></TD></TR>
          <TR><TD ALIGN="LEFT" BGCOLOR="#f8faff">계산값 캐시<BR/>의존값 비교</TD></TR>
        </TABLE>
      >
    ];
  }

  subgraph "cluster_데모앱" {
    label="데모 앱";
    color="#86efac";
    style="rounded,filled";
    fillcolor="#f0fdf4";
    penwidth=1.4;

    "루트_앱" [
      label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="8" COLOR="#4ade80">
          <TR><TD BGCOLOR="#dcfce7"><B>루트 앱</B></TD></TR>
          <TR><TD ALIGN="LEFT" BGCOLOR="#f9fff9">설정 상태<BR/>현재 페이지<BR/>카드 목록<BR/>선택 카드 ID<BR/>상세 정보 사전<BR/>현재 페이지 렌더</TD></TR>
        </TABLE>
      >
    ];

    "브이노드_생성기" [
      label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="8" COLOR="#4ade80">
          <TR><TD BGCOLOR="#dcfce7"><B>브이노드 생성기</B></TD></TR>
          <TR><TD ALIGN="LEFT" BGCOLOR="#f9fff9">가상 노드 생성</TD></TR>
        </TABLE>
      >
    ];
  }

  subgraph "cluster_VDOM엔진" {
    label="가상 노드 엔진";
    color="#fda4af";
    style="rounded,filled";
    fillcolor="#fff1f2";
    penwidth=1.4;

    "엔진" [
      label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="8" COLOR="#fb7185">
          <TR><TD BGCOLOR="#fecdd3"><B>가상 노드 엔진</B></TD></TR>
          <TR><TD ALIGN="LEFT" BGCOLOR="#fff8f8">최초 렌더<BR/>패치 적용<BR/>되돌리기<BR/>다시 실행<BR/>상태 점검</TD></TR>
        </TABLE>
      >
    ];

    "비교기" [
      label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="8" COLOR="#fb7185">
          <TR><TD BGCOLOR="#ffe4e6"><B>비교기</B></TD></TR>
          <TR><TD ALIGN="LEFT" BGCOLOR="#fff8f8">이전 / 다음 가상 노드 비교<BR/>패치 목록 생성</TD></TR>
        </TABLE>
      >
    ];

    "패치_적용기" [
      label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="8" COLOR="#fb7185">
          <TR><TD BGCOLOR="#ffe4e6"><B>패치 적용기</B></TD></TR>
          <TR><TD ALIGN="LEFT" BGCOLOR="#fff8f8">실제 문서 노드 변경 적용</TD></TR>
        </TABLE>
      >
    ];

    "초기_DOM_생성기" [
      label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="8" COLOR="#fb7185">
          <TR><TD BGCOLOR="#ffe4e6"><B>초기 문서 노드 생성기</B></TD></TR>
          <TR><TD ALIGN="LEFT" BGCOLOR="#fff8f8">최초 문서 노드 생성<BR/>노드 교체</TD></TR>
        </TABLE>
      >
    ];

    "히스토리" [
      label=<
        <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="8" COLOR="#fb7185">
          <TR><TD BGCOLOR="#ffe4e6"><B>히스토리</B></TD></TR>
          <TR><TD ALIGN="LEFT" BGCOLOR="#fff8f8">되돌리기 / 다시 실행<BR/>스냅샷 기록</TD></TR>
        </TABLE>
      >
    ];
  }

  "앱_퍼사드" -> "루트_컴포넌트" [label="루트 인스턴스 생성", lhead="cluster_루트런타임"];

  "루트_컴포넌트" -> "루트_앱" [label="루트 앱 실행", ltail="cluster_루트런타임", lhead="cluster_데모앱"];
  "루트_앱" -> "브이노드_생성기" [label="가상 노드 구성"];

  "루트_컴포넌트" -> "현재_디스패처" [label="활성 루트 설정 / 해제"];
  "루트_컴포넌트" -> "자식_트리_전개" [label="자식 전개"];
  "루트_컴포넌트" -> "엔진" [label="엔진 생성 / 사용", lhead="cluster_VDOM엔진"];
  "루트_컴포넌트" -> "이펙트_커밋" [label="문서 노드 반영 후 커밋"];
  "루트_컴포넌트" -> "언마운트_정리" [label="언마운트 정리"];

  "루트_앱" -> "상태_Hook" [label="루트 상태 소유", lhead="cluster_Hook계층"];
  "루트_앱" -> "이펙트_Hook" [label="후처리 등록"];
  "루트_앱" -> "메모_Hook" [label="파생 데이터 계산"];

  "상태_Hook" -> "현재_디스패처" [label="활성 루트 조회"];
  "상태_Hook" -> "업데이트_예약" [label="상태 변경 함수가 재렌더 예약"];
  "이펙트_Hook" -> "현재_디스패처" [label="활성 루트 조회"];
  "메모_Hook" -> "현재_디스패처" [label="활성 루트 조회"];
  "자식_트리_전개" -> "현재_디스패처" [label="자식 훅 금지"];

  "엔진" -> "비교기" [label="변경 목록 계산"];
  "엔진" -> "패치_적용기" [label="문서 노드 갱신"];
  "엔진" -> "초기_DOM_생성기" [label="최초 장착 / 교체"];
  "엔진" -> "히스토리" [label="스냅샷 기록"];
}
